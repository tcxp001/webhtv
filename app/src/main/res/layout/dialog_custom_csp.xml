<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_shell_proxy_dialog"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="16dp"
    android:paddingEnd="20dp"
    android:paddingBottom="12dp">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="12dp">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_weight="1"
            android:text="@string/setting_custom_csp"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/enabled"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minHeight="36dp"
            android:minWidth="84dp"
            android:nextFocusDown="@id/insertMinus"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="@string/setting_disable"
            android:textColor="@color/dialog_tonal_button_text"
            app:backgroundTint="@color/dialog_tonal_button_bg" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_weight="1"
            android:paddingEnd="4dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@string/setting_custom_csp_insert"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/insertMinus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/selector_dialog_step_button"
                android:clickable="true"
                android:contentDescription="@string/setting_custom_csp_insert_decrease"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="&#8722;"
                android:textColor="@color/dialog_outlined_button_text"
                android:textSize="22sp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/insertIndex"
                android:layout_width="42dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/insertPlus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/selector_dialog_step_button"
                android:clickable="true"
                android:contentDescription="@string/setting_custom_csp_insert_increase"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="+"
                android:textColor="@color/dialog_outlined_button_text"
                android:textSize="22sp" />

        </androidx.appcompat.widget.LinearLayoutCompat>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/add"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:minHeight="40dp"
            android:minWidth="76dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="@string/setting_custom_csp_add"
            android:textColor="@color/dialog_tonal_button_text"
            app:backgroundTint="@color/dialog_tonal_button_bg" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/modeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/uiMode"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/setting_proxy_ui_mode"
            android:textColor="@color/dialog_toggle_button_text"
            app:backgroundTint="@color/dialog_toggle_button_bg"
            app:strokeColor="@color/dialog_outlined_button_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/textMode"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/setting_proxy_text_mode"
            android:textColor="@color/dialog_toggle_button_text"
            app:backgroundTint="@color/dialog_toggle_button_bg"
            app:strokeColor="@color/dialog_outlined_button_stroke" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.fongmi.android.tv.ui.custom.CustomNestedScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:overScrollMode="never"
        app:maxHeight="560dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/jsonLayout"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:visibility="gone"
                app:boxBackgroundColor="@color/white"
                app:boxCollapsedPaddingTop="0dp"
                app:boxStrokeColor="@color/dialog_outlined_button_stroke"
                app:hintEnabled="false"
                app:hintTextColor="#5F6368">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/jsonText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="monospace"
                    android:gravity="start|top"
                    android:hint="@string/setting_custom_csp_json_hint"
                    android:imeOptions="actionDone"
                    android:importantForAutofill="no"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:minLines="8"
                    android:scrollHorizontally="true"
                    android:selectAllOnFocus="false"
                    android:singleLine="false"
                    android:textColor="@color/black"
                    android:textColorHint="#666666" />

            </com.google.android.material.textfield.TextInputLayout>

        </FrameLayout>

    </com.fongmi.android.tv.ui.custom.CustomNestedScrollView>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/negative"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:minWidth="0dp"
            android:text="@string/dialog_negative"
            android:textColor="@color/dialog_outlined_button_text"
            app:backgroundTint="@color/dialog_outlined_button_bg"
            app:strokeColor="@color/dialog_outlined_button_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/positive"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:minWidth="0dp"
            android:text="@string/dialog_positive"
            android:textColor="@color/dialog_primary_button_text"
            app:backgroundTint="@color/dialog_primary_button_bg" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.appcompat.widget.LinearLayoutCompat>
